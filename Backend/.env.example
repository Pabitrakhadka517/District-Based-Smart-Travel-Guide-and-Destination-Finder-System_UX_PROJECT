# NepalYatra API environment variables
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/nepayatra

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins (the Next.js frontend)
CORS_ORIGIN=http://localhost:3000

# Used to build links in emails (e.g. password reset)
FRONTEND_URL=http://localhost:3000

# Email (SMTP) — leave blank in dev to print tokens/links to console instead.
# Works with Mailtrap sandbox (https://mailtrap.io) for safe testing:
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USER=your_mailtrap_username
# EMAIL_PASS=your_mailtrap_password
# EMAIL_FROM=NepalYatra <noreply@nepayatra.com>

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Max upload size per image, in MB
MAX_UPLOAD_SIZE_MB=5
